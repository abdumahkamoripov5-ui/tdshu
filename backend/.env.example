# ===== Admin login (.env fayliga ko'chiring va ALBATTA o'zgartiring) =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=BU_YERGA_KUCHLI_PAROL_YOZING

# ===== Token imzolash kaliti =====
# Tasodifiy uzun satr yozing. Belgilanmasa, har restartda yangisi yaratiladi
# (admin qaytadan kirishga majbur bo'ladi). Yaratish: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=
TOKEN_TTL_SECONDS=28800

# ===== CORS — frontend domeningiz =====
# Faqat shu domenlardan API'ga ruxsat beriladi (vergul bilan ajrating).
# Sinov uchun "*" qoldirsa bo'ladi, lekin production'da o'z domeningizni yozing.
# Masalan: https://tdshu-tarjima.netlify.app
ALLOWED_ORIGINS=*

# ============================================================
# MA'LUMOTLAR BAZASI
# DATABASE_URL berilsa -> PostgreSQL (Supabase) ishlatiladi.
# Bo'sh qoldirilsa     -> mahalliy SQLite (faqat ishlab chiqish uchun).
# Supabase'da: Project Settings -> Database -> Connection string.
# "Session pooler" yoki "Transaction pooler" satrini oling (port 6543/5432).
# ============================================================
DATABASE_URL=
# Masalan:
# DATABASE_URL=postgresql://postgres.xxxx:PAROL@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ============================================================
# SUPABASE STORAGE (rasm va PDF fayllar uchun)
# SUPABASE_URL + SUPABASE_SERVICE_KEY berilsa -> Supabase Storage.
# Bo'sh qoldirilsa                            -> mahalliy uploads/ papka.
# Supabase'da: Project Settings -> API
#   SUPABASE_URL         = "Project URL"
#   SUPABASE_SERVICE_KEY = "service_role" kaliti (MAXFIY! faqat backendda saqlang)
# Storage bo'limida `uploads` nomli PUBLIC bucket yarating.
# ============================================================
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=uploads

# ===== Server =====
# Production'da DEBUG ni HECH QACHON true qilmang.
DEBUG=false
PORT=5000

# ===== SMTP — email yuborish uchun (Gmail misoli) =====
# Gmail uchun "App Password" yarating: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Murojaatlar va yangi maqolalar haqida xabar keladigan email
NOTIFY_EMAIL=
