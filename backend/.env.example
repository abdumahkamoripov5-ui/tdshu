# Admin login (.env fayliga ko'chiring va o'zgartiring)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# SMTP — email yuborish uchun (Gmail misoli)
# Gmail uchun "App Password" yarating: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Murojaatlar va yangi maqolalar haqida xabar keladigan email
NOTIFY_EMAIL=
